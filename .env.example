SQLITE_PATH=./arbitrage_bot.db
TARGET_MARKET_MODE=btc_15m
POLYMARKET_BASE_URL=https://gamma-api.polymarket.com
KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2
HTTP_TIMEOUT_SECONDS=15
MIN_DAYS_TO_EXPIRY=7
MAX_DAYS_TO_EXPIRY=49
MAX_MATCH_DATE_DRIFT_DAYS=2
MAX_MATCH_TIME_DRIFT_MINUTES=20
MIN_SIMILARITY_SCORE=0.35
DISCOVERY_SCAN_LIMIT=1000
REDISCOVERY_INTERVAL_ITERATIONS=15
ENABLE_AUTO_FALLBACK=true
TRACKED_PAIR_LIMIT=25
PROFIT_THRESHOLD=0.00
SCAN_LIMIT=200
